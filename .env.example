# Mock 服务器运行时监听的 HTTP 端口
PORT=3000

# 逗号分隔的 HAR 文件列表（支持相对或绝对路径），示例：
# HAR_PATHS=history.har
# HAR_PATHS=history.har, recordings/extra.har
HAR_PATHS=history.har

# URL 相似度的权重，用于调节路径与查询串的重要性（填正数即可，程序会自动归一化）
MATCH_URL_PATH_WEIGHT=0.8
MATCH_URL_QUERY_WEIGHT=0.2

# 路径相似度权重，用于控制前缀匹配与编辑距离的占比
MATCH_PATH_PREFIX_WEIGHT=0.6
MATCH_PATH_DISTANCE_WEIGHT=0.4

# 结构化请求体相似度权重，用于控制字段名 vs. 字段+值组合的重要性
MATCH_STRUCTURED_KEY_WEIGHT=0.4
MATCH_STRUCTURED_ENTRY_WEIGHT=0.6

# 当请求体格式完全不一致时的最低相似度分值
MATCH_PAYLOAD_MISMATCH_FLOOR=0.1
